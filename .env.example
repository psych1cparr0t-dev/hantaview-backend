NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# API timeouts (ms)
CDC_TIMEOUT=10000
WHO_TIMEOUT=10000
ECDC_TIMEOUT=10000

# Cache TTL (seconds)
CACHE_TTL_CASES=3600
CACHE_TTL_STATS=1800
CACHE_TTL_OUTBREAK=86400
CACHE_TTL_SOURCE_STATUS=300

# Admin auth (for manual refresh endpoint)
ADMIN_API_KEY=change_me_before_production

# CORS origins (comma-separated)
CORS_ORIGIN=http://localhost:3000,http://localhost:8080

# Logging
LOG_FILE=./logs/hantaview.log

# Optional Redis (leave blank to use in-memory cache)
# REDIS_URL=redis://localhost:6379

# ── Alert email (Resend) ─────────────────────────────────────────────────────
# Get your free API key at https://resend.com — 100 emails/day on the free plan.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# "From" address shown in alert emails. Must be a verified Resend domain.
# In development you can use resend.dev testing addresses.
ALERTS_FROM_EMAIL=Hantaview Alerts <alerts@yourdomain.com>

# Public URL of this backend (used for unsubscribe links in emails)
API_BASE_URL=https://hantaview-backend.onrender.com

# Public URL of the frontend dashboard (used in email CTAs)
DASHBOARD_URL=https://psych1cparr0t-dev.github.io/hantaview/

# Directory where alerts.db is stored. Use an absolute path on Render
# if you have a Persistent Disk mounted (e.g. /var/data).
# On the free tier the filesystem resets on each deploy; subscriptions
# will be lost — upgrade to a Persistent Disk ($1/month) to retain them.
DATA_DIR=./data
