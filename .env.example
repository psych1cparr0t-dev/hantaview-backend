NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# API timeouts (ms)
CDC_TIMEOUT=10000
WHO_TIMEOUT=10000
ECDC_TIMEOUT=10000

# Cache TTL (seconds)
CACHE_TTL_CASES=3600
CACHE_TTL_STATS=1800
CACHE_TTL_OUTBREAK=86400
CACHE_TTL_SOURCE_STATUS=300

# Admin auth (for manual refresh endpoint)
ADMIN_API_KEY=change_me_before_production

# CORS origins (comma-separated)
CORS_ORIGIN=http://localhost:3000,http://localhost:8080

# Logging
LOG_FILE=./logs/hantaview.log

# Optional Redis (leave blank to use in-memory cache)
# REDIS_URL=redis://localhost:6379
