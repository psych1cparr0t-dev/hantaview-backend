{
  "name": "hantaview-backend",
  "version": "1.0.0",
  "description": "Real-time hantavirus surveillance data aggregation backend",
  "main": "src/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/ tests/"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "node-cache": "^5.1.2",
    "resend": "^6.12.3",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
    "xml2js": "^0.6.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nock": "^13.5.4",
    "nodemon": "^3.1.4"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js"
    ]
  }
}
